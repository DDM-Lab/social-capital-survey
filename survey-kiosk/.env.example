# Copy to .env and fill in. Values here are read at startup by config/settings.py.

# Core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
BASE_URL=http://localhost:8000

# Database (Postgres in production; omit to use the local SQLite fallback)
# DATABASE_URL=postgres://user:password@host:5432/survey

# Identity / delivery
TARGET_DOMAIN=andrew.cmu.edu

# Timing
QR_ROTATE_SECONDS=5
TOKEN_TTL_SECONDS=15
SURVEY_TTL_MINUTES=20
VERIFY_TTL_HOURS=24

# Email (Postmark via Anymail). Omit POSTMARK_SERVER_TOKEN to print emails to console.
# POSTMARK_SERVER_TOKEN=your-postmark-server-token
DEFAULT_FROM_EMAIL=Survey Kiosk <noreply@andrew.cmu.edu>
